# ── Reward Functions (5 camadas da pesquisa) ──

def _get(c):
    """Extrai content do completion (list ou dict)."""
    if isinstance(c, list):
        return c[0].get("content", "")
    return c.get("content", "")


def _block(content, tag):
    """Extrai bloco entre tags XML."""
    m = re.search(rf"<{tag}>([\s\S]+?)</{tag}>", content)
    return m.group(1).strip() if m else ""


# R1: FORMATO (pesquisa: "Recompensa de Formato")
def format_reward(completions, **kwargs):
    """Valida estrutura XML: <reasoning>, <answer>, <tests>."""
    scores = []
    for c in completions:
        t = _get(c)
        s = 0.0

        # Raciocínio substancial
        if re.search(r"<reasoning>[\s\S]{50,}?</reasoning>", t):
            s += 0.8
        elif re.search(r"<reasoning>[\s\S]+?</reasoning>", t):
            s += 0.3

        # Resposta substancial
        if re.search(r"<answer>[\s\S]{30,}?</answer>", t):
            s += 0.8
        elif re.search(r"<answer>[\s\S]+?</answer>", t):
            s += 0.3

        # Bonus: inclui testes (CURE)
        if re.search(r"<tests>[\s\S]+?</tests>", t):
            s += 0.4

        # Penalização leve se não tem estrutura nenhuma
        if "<reasoning>" not in t and "<answer>" not in t:
            s -= 0.5

        scores.append(s)
    return scores


# R2: COMPILAÇÃO (pesquisa: "Recompensa de Compilação")
def code_quality_reward(completions, **kwargs):
    """Avalia qualidade: keywords gráficas + estrutura + ast.parse."""
    KW = [
        "three", "scene", "camera", "renderer", "mesh",
        "geometry", "material", "requestanimationframe",
        "gl_position", "gl_fragcolor", "uniform", "varying",
        "void main", "vec3", "vec4", "mat4",
        "canvas", "getcontext", "fillrect", "beginpath", "arc",
        "class ", "def ", "import ", "self.", "pygame",
        "createshader", "linkprogram", "drawarrays",
        "bindtexture", "bindframebuffer",
    ]

    scores = []
    for c in completions:
        code = _block(_get(c), "answer")
        if not code:
            scores.append(-0.5)
            continue

        s = 0.0
        cl = code.lower()

        # Keywords gráficas
        n = sum(1 for k in KW if k in cl)
        if n >= 6:
            s += 2.0
        elif n >= 3:
            s += 1.0
        elif n >= 1:
            s += 0.5

        # Python: tenta compilar
        if "def " in code and "import" in code:
            try:
                ast.parse(code)
                s += 0.5
            except SyntaxError:
                s -= 0.3

        # Estrutura de código (não é string morta)
        pts = [
            r"function\s+\w+\s*\(",
            r"class\s+\w+",
            r"const\s+\w+\s*=",
            r"void\s+main\s*\(",
            r"def\s+\w+\s*\(",
            r"for\s*\(",
        ]
        s += min(sum(1 for p in pts if re.search(p, code)) * 0.15, 0.5)

        scores.append(s)
    return scores


# R3: 3D-SPO (pesquisa: "Recompensa de Lógica Espacial")
def spatial_reward(completions, **kwargs):
    """Coerência espacial: posições, rotações, math, projeções."""
    P = [
        (r"position\.set\s*\(", 0.25),
        (r"new\s+THREE\.Vector[23]\s*\(", 0.25),
        (r"lookAt\s*\(", 0.2),
        (r"rotation\.\w\s*[\+\-\*]?=", 0.2),
        (r"Math\.(?:sin|cos|atan2?|sqrt|PI)\b", 0.2),
        (r"normalize\s*\(", 0.15),
        (r"cross\s*\(|dot\s*\(", 0.2),
        (r"projectionMatrix|modelViewMatrix", 0.2),
        (r"intersect|collision|colliderect", 0.2),
        (r"raycaster|raycast", 0.15),
        (r"clamp|lerp|smoothstep|mix\s*\(", 0.15),
        (r"shadow|castShadow|receiveShadow", 0.1),
    ]

    scores = []
    for c in completions:
        code = _block(_get(c), "answer")
        if not code:
            scores.append(0.0)
            continue

        total = sum(w for p, w in P if re.search(p, code, re.IGNORECASE))
        scores.append(min(total, 1.5))
    return scores


# R4: CURE (pesquisa: "Framework CURE — co-evolução código + testes")
def cure_reward(completions, **kwargs):
    """Valida coerência entre <answer> e <tests>."""
    scores = []
    for c in completions:
        t = _get(c)
        code = _block(t, "answer")
        tests = _block(t, "tests")

        if not code or not tests:
            scores.append(0.0)
            continue

        s = 0.0

        # Testes substanciais
        lines = [
            l for l in tests.split("\n")
            if l.strip() and not l.strip().startswith(("//", "#"))
        ]
        if len(lines) >= 3:
            s += 0.5
        elif len(lines) >= 1:
            s += 0.2

        # Coerência: testes referenciam variáveis do código
        identifiers = set(re.findall(
            r"\b(?:const|let|var|class|function|def)\s+(\w+)", code
        ))
        refs = sum(1 for i in identifiers if i.lower() in tests.lower())
        if refs >= 3:
            s += 0.5
        elif refs >= 1:
            s += 0.25

        # Usa assertions
        if any(re.search(p, tests) for p in [
            r"console\.assert", r"\bassert\s+", r"expect\s*\("
        ]):
            s += 0.3

        scores.append(min(s, 1.5))
    return scores


# R5: RACIOCÍNIO (pesquisa: "Decompor álgebra linear antes de implementar")
def reasoning_reward(completions, **kwargs):
    """Recompensa raciocínio matemático e técnico no <reasoning>."""
    IND = [
        r"(?:angle|radian|ângulo|graus)",
        r"(?:matrix|matriz|transform)",
        r"(?:vector|vetor|normal|tangent)",
        r"(?:interpolat|lerp|slerp|bezier)",
        r"(?:projection|projeção|perspectiv)",
        r"(?:fragment|vertex|rasteriz|pipeline)",
        r"(?:O\(n|complexidade|performance|otimiz)",
        r"(?:collision|colisão|AABB|bounding)",
        r"(?:buffer|framebuffer|texture|sampler)",
    ]

    scores = []
    for c in completions:
        reasoning = _block(_get(c), "reasoning")
        if not reasoning:
            scores.append(0.0)
            continue

        found = sum(1 for p in IND if re.search(p, reasoning, re.IGNORECASE))

        s = 0.0
        if found >= 4:
            s = 1.0
        elif found >= 2:
            s = 0.5
        elif found >= 1:
            s = 0.25

        # Bonus: raciocínio longo = mais profundo
        words = len(reasoning.split())
        if words >= 100:
            s += 0.3
        elif words >= 50:
            s += 0.15

        scores.append(min(s, 1.0))
    return scores


